FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV MODEL_PATH=/app/funasr-deploy/models/FunAudioLLM/Fun-ASR-Nano-2512
ENV MODELSCOPE_CACHE=/app/funasr-deploy/models
ENV DEVICE=cpu
ENV PORT=10095
ENV NGPU=0
ENV NCPU=4

# 系统依赖 + 编译工具链（CTC 扩展必须）
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    python3-venv \
    ffmpeg \
    git \
    git-lfs \
    wget \
    curl \
    build-essential \
    g++ \
    make \
    cmake \
    swig \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 拷贝 FunASR 源码
COPY FunASR-src /app/FunASR-src

# 先装 PyTorch CPU
RUN pip3 install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    torch torchaudio

# 从源码安装 FunASR，确保 CTC 等扩展被编译
RUN cd /app/FunASR-src && \
    pip3 install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    -e .[all]

# 额外安装 WebSocket 和常用依赖
RUN pip3 install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    websockets \
    numpy \
    modelscope \
    transformers \
    sentencepiece \
    protobuf \
    tqdm \
    requests \
    aiohttp

# 再单独装一下 tiktoken（Fun-ASR-Nano 依赖 LLM 时常需要）
RUN pip3 install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    tiktoken

# 把部署脚本拷贝进来（你之前用的 Fun-ASR-Nano-2512-Deploy）
COPY Fun-ASR-Nano-2512-Deploy /app/funasr-deploy

WORKDIR /app/funasr-deploy

EXPOSE 10095

CMD python3 funasr_wss_server.py \
    --host 0.0.0.0 \
    --port "${PORT}" \
    --asr_model "${MODEL_PATH}" \
    --asr_model_online "${MODEL_PATH}" \
    --device "${DEVICE}" \
    --ngpu "${NGPU}" \
    --ncpu "${NCPU}"
